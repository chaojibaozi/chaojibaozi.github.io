# 统一换行符配置
* text=auto eol=lf

# 文本文件使用 LF 换行符
*.txt         text eol=lf
*.html        text eol=lf
*.css         text eol=lf
*.js          text eol=lf
*.json        text eol=lf
*.md          text eol=lf

# 图片和二进制文件不转换
*.png         -text
*.jpg         -text
*.gif         -text
*.ico         -text
*.zip         -text
